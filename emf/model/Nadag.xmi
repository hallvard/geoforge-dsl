<?xml version="1.0" encoding="UTF-8"?>
<geoforge:Model
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:geoforge="http://www.example.org/geoforge"
    xsi:schemaLocation="http://www.example.org/geoforge geoforge.ecore"
    name="Nadag"
    namespace="no.ngu"
    version="1.0.0">
  <typeDefs
      xsi:type="geoforge:FeatureType"
      name="GeotekniskUnders"
      description="Toppnivå-objektet, med polygon som rammer inn alle borehull på nivået under."
      title="Geoteknisk undersøkelse">
    <properties
        xsi:type="geoforge:IdentityProperty"
        name="identifikasjon"
        title="Identifikasjon">
      <type
          xsi:type="geoforge:PropertyTypeRef"
          typeRef="//@typeDefs.1"/>
    </properties>
    <properties
        xsi:type="geoforge:Property"
        name="område">
      <type
          xsi:type="geoforge:PropertyTypeRef">
        <typeRef
            xsi:type="geoforge:GeometryType"
            href="Common.xmi#//@typeDefs.5"/>
      </type>
    </properties>
    <properties
        xsi:type="geoforge:Property"
        name="prosjektnavn"
        title="Prosjektnavn">
      <type
          xsi:type="geoforge:PropertyTypeRef">
        <typeRef
            xsi:type="geoforge:BuiltinType"
            href="Common.xmi#//@typeDefs.0"/>
      </type>
    </properties>
    <properties
        xsi:type="geoforge:Property"
        name="opprettetDato">
      <type
          xsi:type="geoforge:PropertyTypeRef">
        <typeRef
            xsi:type="geoforge:BuiltinType"
            href="Common.xmi#//@typeDefs.2"/>
      </type>
      <multiplicity
          max="1"/>
    </properties>
    <properties
        xsi:type="geoforge:Property"
        name="sistEndretDato">
      <type
          xsi:type="geoforge:PropertyTypeRef">
        <typeRef
            xsi:type="geoforge:BuiltinType"
            href="Common.xmi#//@typeDefs.2"/>
      </type>
      <multiplicity
          max="1"/>
    </properties>
    <properties
        xsi:type="geoforge:Relation"
        name="undersPkt">
      <type
          xsi:type="geoforge:PropertyTypeRef"
          typeRef="//@typeDefs.2"/>
      <multiplicity
          max="-1"/>
    </properties>
  </typeDefs>
  <typeDefs
      xsi:type="geoforge:DataType"
      name="Identifikasjon">
    <properties
        xsi:type="geoforge:Property"
        name="lokalId">
      <type
          xsi:type="geoforge:PropertyTypeRef">
        <typeRef
            xsi:type="geoforge:BuiltinType"
            href="Common.xmi#//@typeDefs.0"/>
      </type>
      <multiplicity
          min="1"
          max="1"/>
    </properties>
    <properties
        xsi:type="geoforge:Property"
        name="navnerom">
      <type
          xsi:type="geoforge:PropertyTypeRef">
        <typeRef
            xsi:type="geoforge:BuiltinType"
            href="Common.xmi#//@typeDefs.0"/>
      </type>
      <multiplicity
          min="1"
          max="1"/>
    </properties>
    <properties
        xsi:type="geoforge:Property"
        name="versjonId">
      <type
          xsi:type="geoforge:PropertyTypeRef">
        <typeRef
            xsi:type="geoforge:BuiltinType"
            href="Common.xmi#//@typeDefs.0"/>
      </type>
      <multiplicity
          min="1"
          max="1"/>
    </properties>
  </typeDefs>
  <typeDefs
      xsi:type="geoforge:FeatureType"
      name="GeotekniskBorehull"
      description="Toppnivå-objektet, med polygon som rammer inn alle borehull på nivået under."
      title="Geoteknisk borehull">
    <properties
        xsi:type="geoforge:IdentityProperty"
        name="identifikasjon"
        title="Identifikasjon">
      <type
          xsi:type="geoforge:PropertyTypeRef"
          typeRef="//@typeDefs.1"/>
    </properties>
    <properties
        xsi:type="geoforge:Property"
        name="posisjon">
      <type
          xsi:type="geoforge:PropertyTypeRef">
        <typeRef
            xsi:type="geoforge:GeometryType"
            href="Common.xmi#//@typeDefs.3"/>
      </type>
    </properties>
    <properties
        xsi:type="geoforge:Relation"
        name="geotekniskUnders"
        opposite="//@typeDefs.0/@properties.5">
      <type
          xsi:type="geoforge:PropertyTypeRef"
          typeRef="//@typeDefs.0"/>
      <multiplicity
          min="1"
          max="1"/>
    </properties>
  </typeDefs>
</geoforge:Model>
