layer "penetrasjon av en trykksonde på enden av en serie med sylindriske trykksonderingsstenger ned i grunnen med konstant hastighet, brukes for å bestemme lagdeling og jordart i løsmasser, samt mekaniske egenskaper for jorden<engelsk>penetration of a probe at the end of a series with cylindrical rods into the ground at the constant rate of penetration, used to determine stratification and soil type, together with mechanical properties of the soil</engelsk>"
  Trykksondering "PenetrationTest" extends GeotekniskInsituTest {
  "arealforhold for trykksonde for korreksjon av målt spissmotstand for poretrykkseffekter<engelsk>area ratio for CPT probe for correction of measured cone resistance for pore pressure effects</engelsk>"
    alpha?: Real
  "øvrige faktorer for korreksjon av trykksonderingsdata, for eksempel korreksjon av målt sidefriksjon<engelsk>other factors for correction of CPT data, for example correction of measured sleeve friction</engelsk>"
    cptKorreksjonsFaktor "initialFrictionalResistance (?)"?: Real
  "type filter for måling av poretrykk (porøst filter, ferdigmettet, spaltefilter)<engelsk>type of filter for measurement of pore pressure (porous filter, pre-saturated filter, slot filter)</engelsk>"
    filterType "filterType"?: CharacterString
  "referanseverdi for spissmotstand ved start av måling (eksempel ved start dissipasjonstest) [MPa] <engelsk>reference value cone resistance at the start of the test (e.g. at the start of a dissipation test)</engelsk>"
    initiellSpissmotstand "initialPointPressure"?: Real
  "medium som benyttes for metting av målesystem for poretrykk<engelsk>medium used for saturation of measuring system for pore pressure</engelsk>"
    metningsMedium "saturationMedium"?: CharacterString
  "kapasitet for anvendt nedpressingsutstyr [kN] <engelsk>capacity for applied thrust machine</engelsk>"
    nedpressingsKapasitet?: NedpressingsKapasitet
  "nedpressingshastighet ved penetrasjon av trykksonderingsstenger (standard er 20 mm/s ± 5 mm/s) [mm/s] <engelsk>rate of penetration for rod system (standard is 20 mm/s ± 5 mm/s)</engelsk>"
    nedpressningsHastighet "rateOfPenetration"?: Real
  "korreksjon for registrert nullpunktsavvik før og etter sondering <engelsk>correction for recorded zero load drift before and after sounding</engelsk>"
    nullpunktsKorreksjon "initialPorePressure, zeroPointCorrection,"?: Real
  "korreksjonsfaktor for bruk av friksjonsreduksjonsring <engelsk>correction factor for use of friction reducer</engelsk>"
    rørKappeKorreksjonsFaktor "mantelareaFaktor,sleeveAreaFactor"?: Real
  "korreksjon av målt sidefriksjon på grunn av poretrykkseffekter<engelsk>correction of measured sleeve friction due to pore pressure effects</engelsk>"
    sidefriksjonKorreksjon "sideFrictionCorrection"?: Real
  "identifikasjon av trykksonde ved hjelp av ID-nummer <engelsk>identification of probe by an ID-number</engelsk>"
    sondeIdentifikasjon?: CharacterString
  "dato for kalibrering av trykksonde, oppgis på kalibreringssertifikat<engelsk>date for calibration of probe, given on the calibration certificate</engelsk>"
    sondeKalibreringDato?: DateTime
  "kvalitetsklasse for målenøyaktighet for en trykksonde ved gjennomføring av anbefalt prøvingsprosedyre <engelsk>application class for test accuracy for test performance according to a recommended test procedure</engelsk>"
    sondeKvalitetKlasse?: SondeKvalitetsKlasse
  "korreksjonsfaktor for trykksonde ved korreksjon av målt spissmotstand for poretrykkseffekter<engelsk>correction factor for measured cone resistance for pore pressure effects</engelsk>"
    spissKorreksjonFaktor "pointAreaFactor"?: Real
  "type trykksonde, avhengig av størrelse og instrumentering<engelsk>type of probe, depending on size and instrumentation</engelsk>"
    spissType "pointType"?: CharacterString
  "<engelsk>Gets or sets the atmospheric pressure correction [MPa].\r\n@value The atmospheric pressure correction.</engelsk>"
    atmosferiskTrykkKorreksjon "AtmosphericPressureCorrection"?: Real
  "<engelsk>Gets or sets the sleeve distance correction [m].\r\n@value The sleeve distance correction.</engelsk>"
    hylseRadieKorreksjon "sleeveDistanceCorrection"?: Real
  inSituPoretrykkObservasjon*: PoretrykkDataInsitu
  trykksonderingObservasjon*: TrykksonderingData
  dissipasjonObservasjon*: DissipasjonData
}

