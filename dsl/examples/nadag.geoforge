model ngu.nadag

builtin Boolean

builtin CharacterString

builtin Date

builtin DateTime

builtin Flate

builtin GM_MultiSurface

builtin GM_Surface

builtin Integer

builtin Kurve

builtin Punkt

builtin Real

abstract layer "metode som brukes i en geoteknisk borhullundersøkelse for å observere og måle egenskaper til de forskjellige jordlag <engelsk>method used in a geotechnical borehole investigation to observe and measure properties of the different soil layers</engelsk>"
  GeotekniskInsituTest "GeotechnicalInsituTest" extends Geotekniskmetode {
  "lengde målt fra toppen av kurven/linja som beskriver borehullforløpet [m] <engelsk>distance measured from the top of  the curve describing the borehole geometry</engelsk>"
    fraBorlengde?: Real
  "lengde målt fra toppen av kurven/linja som beskriver borehullforløpet [m] <engelsk>distance measured from the top of  the curve describing the borehole geometry</engelsk>"
    tilBorlengde?: Real
  "tidspunkt for start av in situ prøvningen<engelsk>start time for in situ testing</engelsk>"
    insituTestStartTidspunkt "investigationStartDate"?: DateTime
  "tidspunkt for stopp av in situ prøvningen<engelsk>stop time for in situ testing</engelsk>"
    insituTestSluttTidspunkt "investigationEndDate"?: DateTime
}

abstract layer "geografisk punkt hvor det er utført målinger <engelsk> geographical location where measurements have been performed </engelsk>"
  GeotekniskObservasjon "Observation" extends GeotekniskObservasjon_NADAG {
  parent tilhørerGB?: GeotekniskBorehull
}

abstract layer "geografisk punkt hvor det er utført observasjoner <engelsk>geographical location where observations have been carried out</engelsk>"
  GeotekniskObservasjon_NADAG "GeotechnicalBoreholeInvestigation" extends GeovitenskapeligObservasjon {
  boreBeskrivelse "description"?: CharacterString
  "vinkelen mellom en referansevektor i et referanseplan og en annen vektor i det samme planet som peker mot noe av interesse"
    boretAzimuth?: Real
  "helning hvor  90 grader er vertikalt , 0 grader er horisontalt"
    boretHelningsgrad "inclination, slope"?: Real
  "total lengde av borehullets forløp, tilsvarer dyp ved vertikal boring"
    boretLengde "boringLength (Depth),"?: Real
  "dybde til fjell som ikke er målt men basert på tolkning"
    boretLengdeTilBerg?: BorlengdeTilBerg
  "avstanden fra måleutstyret og ned til det punkt på jordoverflaten hvor boring/måling faktisk starter\r\n\r\nMerknad: Borehullundersøkelsens posisjon er vanligvis angitt med x,y,z-koordinat. Disse verdiene representerer vanligvis et punkt på jordoverflaten. Dybden fra denne gitte posisjon vil da være 0. Hvis boringen derimot er utført fra flåte,  skip eller is, er det viktig at dybdeFraGittPosisjon blir angitt. Denne vil da være avstanden fra måleutstyrets senter (0 dybde) og ned til havbunnen, innsjøbunnen eller elvebunnen hvor sonderingen/boringen faktisk starter fra).\r\n\r\n<engelsk>\r\ndistance from the drill or measure equipment down to the vertical level where the borehole/measurement actually begins\r\n\r\nNote: This is important to specify if the drilling/sounding is performed from e.g. a raft, ship or from ice. The depth will then be the depth from the measuring equipments origin (0 depth) and down to where drilling/sounding actually begins (on the sea surface, bottom of a lake or river, etc.)\r\n\r\n</engelsk>"
    dybdeFraGittPosisjon "depthFromRaft"?: Real
  "den lengden hvor sonderingsutstyret befinner seg i vann"
    dybdeFraVannoverflaten "freeWaterDepth"?: Real
  "Lenke til mer informasjon (URL)"
    lenkeTilTileggsinfo?: CharacterString
  "beskrivelse av værforhold under utførelsen av borehullundersøkelsen\r\n<engelsk>\r\nWeather conditions - general description.\r\n</engelsk>"
    værforholdVedBoring "weatherConditions"?: CharacterString
  "Høyde for observasjon ved start observasjon [m]"
    høyde?: Real
  "Referansesystem for høydeangivelse, som EPSG-kode."
    høydeReferanse?: NADAG_Hoeyderef
  "Nummer på observasjon benyttet i den geotekniske undersøkelsen"
    undersøkelseNr "surveyNo"?: CharacterString
  "Identifikasjon av et objekt, ivaretatt av den ansvarlige levernadør, som kan benyttes av eksterne applikasjoner som referanse til objektet."
    eksternIdentifikasjon?: EksternIdentifikasjon
  "Når objektet ble opprettet i database (Nadag)"
    opprettetDato: DateTime
  "dybde [m] fra terrengoverflaten til det nivå i grunnen der alle porene i jorden er mettet med vann og poretrykket begynner å stige <engelsk>depth [m] from the terrain surface to the level in the ground where all voids are saturated with water, and where the pore pressure starts to increase</engelsk>"
    dybdeGrunnvannstand "groundWaterDept, groundWaterLevel"?: Real
  "diameter [mm] av forboret hull i en borhullundersøkelse <engelsk>diameter (mm)     of a predrilled hole in a borehole investigation</engelsk>"
    forboretDiameter "preBoringDiameter"?: Real
  "Lengde[m] av forboret hull i en borhullundersøkelse <engelsk>Length[m] of a predrilled borehole in a borehole investigation<engelsk>"
    forboretLengde "preBoringLength"?: Real
  "metode brukt til boring uten registrering av data<engelsk>pre boring method</engelsk>"
    forboringMetode "preBoringmethod"?: CharacterString
  "tosifret tall som benyttes for å angi årsak til avslutning av borehullundersøkelse<engelsk>code used to explain the reason for termination of a borehole investigation<engelsk>"
    stoppKode "terminationCode"?: GeotekniskStoppkode
  "startlengde[m] for hvor forboring startet i en borhullundersøkelse <engelsk>start depth[m] where the predrilling in the  borehole investigation started<engelsk>"
    forboretStartLengde "preBoringStartLength"?: Real
}

abstract layer "innsamling av fysisk prøvemateriale som inndeles i prøvedeler hvor det for hver prøvedel kan utføres ett eller flere geotekniske laboratorieforsøk <engelsk>sampling of physical material separated into sample parts, where one or several laboratory tests can be carried out on each part</engelsk>"
  GeotekniskProevetaking "GeotechnicalSampling" extends Geotekniskmetode {
  "lengde målt fra toppen av kurven/linja som beskriver borehullforløpet [m] <engelsk>distance measured from the top of  the curve describing the borehole geometry</engelsk>"
    fraBorlengde?: Real
  "lengde målt fra toppen av kurven/linja som beskriver borehullforløpet [m] <engelsk>distance measured from the top of  the curve describing the borehole geometry</engelsk>"
    tilBorlengde?: Real
  "klassifisering av fysisk prøvemateriale, avhengig av type prøvetaking og jordart<engelsk>classification of sampled material, depending on type of sampling and soil type</engelsk>"
    prøvetype?: ProevetakingType
  "vekt pr. volumenhet [kg/m3] <engelsk>weight by unit of space (kg/m3)</engelsk>"
    densitetPrøvetaking?: Real
  "beskrivelse og resultater fra miljøteknisk undersøkelse <engelsk>description and results from environmental investigation<engelsk>"
    miljøtekniskUndersøkelse?: CharacterString
}

abstract layer "metode som brukes i en grunnundersøkelse for å måle penetrasjonsmotstanden i de forskjellige jordlag <engelsk>method used in a ground investigation to measure the penetration resistance of various soil layers</engelsk>"
  GeotekniskSondering "GeotechnicalSounding" extends Geotekniskmetode {
  "lengde målt fra toppen av kurven/linja som beskriver borehullforløpet [m] <engelsk>distance measured from the top of  the curve describing the borehole geometry</engelsk>"
    fraBorlengde?: Real
  "lengde målt fra toppen av kurven/linja som beskriver borehullforløpet [m] <engelsk>distance measured from the top of  the curve describing the borehole geometry</engelsk>"
    tilBorlengde?: Real
  "tykkelse på torvlag i meter [m] <engelsk>thickness of peat in meter</engelsk>"
    torvTykkelse?: Real
}

abstract layer "Abstrakt objekttype for å samle felles-egenskaper for en del geotekniske prøver."
  Geotekniskmetode {
  "unik identifikasjon av et objekt"
    identity identifikasjon: Identifikasjon
}

abstract layer "andre typer observasjoner som ikke er samlet inn via fysiske borehull\r\n\r\n<engelsk>\r\nobservations collected by other features, i.e. not borehole.\r\n</engelsk>"
  GeovitenskapeligObservasjon "GeoScientificObservation" extends Supertype_Geotekn_obj_pkt {
  "sted objektet eksisterer på\r\n\r\n<engelsk>\r\nthe actual position determined by measuring device\r\n</engelsk>"
    geometry posisjon: Punkt
  "startdato for observasjon\r\n\r\n<engelsk>\r\nstarting date of the observation\r\n</engelsk>"
    observasjonStart?: DateTime
  "sluttdato for observasjon\r\n\r\n<engelsk>\r\nending date of the observation\r\n</engelsk>"
    observasjonSlutt?: DateTime
  "identifikasjon av operatøren som utfører observasjonen\r\n\r\n<engelsk>\r\nIdentification of the operator performing the observation\r\n</engelsk>"
    observatør?: CharacterString
  "referanse til opphavsmaterialet, kildematerialet, organisasjons/publiseringskilde\r\n\r\nMerknad: \r\nKan også beskrive navn på person og årsak til oppdatering\r\n\r\n<engelsk>\r\nreference to copyright, source, organization/publication source\r\n\r\nNote: May also include name of person and cause of update\r\n\r\n</engelsk>"
    opphav?: CharacterString
}

abstract layer "geovitenskaplig undersøkelse som utføres innen for et gitt område og tidsperiode og som ofte er knyttet til et prosjekt \r\n\r\n<engelsk>\r\nsoil geoscientific investigation of a given area and time period and usually with a connection to a specific project \r\n</engelsk>"
  GeovitenskapeligUndersoekelse "GeoScientificInvestigation" extends Supertype_Geotekn_obj_omr {
  "beskrivelse av de geovitenskaplige undersøkelsene\r\n\r\n<engelsk>\r\ndescription of the geoscientific investigations\r\n</engelsk>"
    beskrivelse?: CharacterString
  "areal som er gjenstand for undersøkelse\r\n\r\n<engelsk> \r\narea coverd by the investigation \r\n</engelsk>"
    geometry område?: GM_Surface
  "identifikasjon av bestiller (kunde) og dennes organisasjon\r\n\r\n<engelsk>\r\nidentifikation of the the customer organisation\r\n</engelsk>"
    oppdragsgiver?: CharacterString
  "identifikasjon av utførende organisasjon\r\n\r\n<engelsk>\r\nidentification of the the organisation responsible for carrying out the project\r\n</engelsk>"
    oppdragstaker?: CharacterString
  "prosjekt navn og/eller nummer\r\n\r\n<engelsk>\r\nname or number of the project - e.g. projectnumber\r\n</engelsk>"
    prosjektNavn?: CharacterString
  "startdato for undersøkelsen\r\n\r\n<engelsk>\r\nstarting date of the investigation\r\n</engelsk>"
    undersøkelsePeriodeFra?: DateTime
  "areal som er gjenstand for undersøkelse\r\n\r\n<engelsk> \r\narea coverd by the investigation \r\n</engelsk>"
    geometry sammensattområde?: GM_MultiSurface
  "sluttdato for undersøkelsen\r\n\r\n<engelsk>\r\nending date of the investigation\r\n</engelsk>"
    undersøkelsePeriodeTil?: DateTime
}

abstract layer "del av et undersøkelsesområde hvor det pågår, skal gjøres eller er gjort geovitenskapelige undersøkelser  \r\n\r\nMerknad: Typisk brukt offshore hvor et undersøkelsesområde er delt i flere mindre lokaliteter.  \r\n\r\n<engelsk> area where geoscientific investigations are planned, in progress or performed. Note: This feature is typically used offshore where an investigation is split into smaller parts</engelsk>"
  GeovitenskapeligUndersoekelseDelomraade "GeoScientificInvestigationSubarea" extends Supertype_Geotekn_obj_omr {
  "forklaring til objektet\r\n<engelsk>\r\ndescription of object\r\n</engelsk>"
    beskrivelse?: CharacterString
  "objektets utstrekning\r\n<engelsk>\r\nextent of object\r\n</engelsk>"
    geometry område: Flate
}

abstract layer "avgrensning av et delområde innenfor en geovitenskapelig undersøkelse\r\n\r\n<engelsk>boundary of a subarea within a geoscientific investigation</engelsk>"
  GeovitenskapeligUndersoekelseDelomraadeGrense "GeoScientificInvestigationSubareaBorder" {
  "forløp som følger overgang mellom ulike fenomener"
    geometry grense: Kurve
}

abstract layer "avgrensning av et område for en geovitenskapelig undersøkelse \r\n\r\n<engelsk>boundary of geoscientific investigation</engelsk>"
  GeovitenskapeligUndersoekelseGrense "GeoScientificInvestigationBorder" {
  "forløp som følger overgang mellom ulike fenomener"
    geometry grense: Kurve
}

abstract layer "område representert ved et punkt hvor det skal foretas en eller flere borehullundersøkelser - også kalt logisk borehull i motsetning til borhullundersøkelse som representerer hvert fysiske borehull\r\n\r\nMerknad: Det logiske borehullet har en posisjon som representerer de fysiske borhullundersøkelsene foretatt i området \r\n\r\n<engelsk>\r\nborehole consists of one or more physical borehole investigations. The borehole has a position, representing a collection of borehole investigations. The position of the borehole is often given the same position as one of the asscoated borehole investigations. The associated borehole investigations should be in a reasonable short distance (e.g. 0,5 m) from the position of the borehole.\r\n</engelsk>"
  GeovitenskapligBorehull "GeoScientificBorehole" extends Supertype_Geotekn_obj_pkt {
  "antall borehullsundersøkeelser i borehullets område \r\n\r\nMerknad: Borhullet er et logisk borhull hvor det innen et lite område er foretatt flere fysiske borhullsundersøkelser som tilhører det samme borehull.\r\n\r\n<engelsk>\r\nNumber of boreholeInvestigations (virtual boreholes) performed at the location of the borehole\r\n\r\nNote: A virtual borehole is a fictitious feature for all boreholes/soundings performed within an reasonable small area (e.g. <5 m or so)</engelsk>"
    antallBorehullUndersøkelser "numberOfBoreholeInvestigations"?: Integer
  "forklaring til objektet og undersøkelser utført på lokaliteten\r\n\r\n<engelsk>\r\na short description of the investigations at the location of the borehole</engelsk>"
    beskrivelse?: CharacterString
  "dybde til berg som ikke er målt men basert på tolkning\r\n\r\n<engelsk>\r\ndepth to bedrock based on interpretation\r\n</engelsk>"
    boretLengdeTilBerg?: BorlengdeTilBerg
  "material som er gjennomboret \r\n\r\nMerknad: spesifisert ved å bruke kodeliste GjennomboretMedium. \r\n\r\n<engelsk>\r\nmaterial penetrated by the borehole\r\n\r\nNote: Specified by using codes from codelist: GjennomboretMedium\r\n</engelsk>"
    gjennomboretMedium "examinedMaterial, drilledMaterial .."*: GjennomboretMedium
  "sted objektet eksisterer på bestemt av måleutstyr\r\n\r\n<engelsk>\r\nthe actual position of the object determined by a measuring device</engelsk>"
    geometry posisjon: Punkt
}

abstract layer "et enkelt fysisk undersøkelsespunkt som inneholder beskrivelsen av borehullforløpet  \r\n\r\nMerknad: Flere undersøkelser kan tilhøre det samme borehullet, men det er undersøkelsen som representerer de enkelte sonderinger / boringer. \r\n\r\n<engelsk>a pysical borehole which contain a description of the borehole geometry Note: Several investigations can belong to the same borehole, and it is the investigation which contain the geometry along the borehole. </engelsk>"
  GeovitenskapligBorehullUndersoekelse "GeoScientificBoreholeInvestigation" extends Supertype_Geotekn_obj_pkt {
  "objektets utstrekning gitt i x,y,z. \r\n\r\nMerknad: Den virkelige posisjonen til denne borehullsundersøkelsen.\r\n\r\n<engelsk>\r\nThe position of the investigation, determined by its x,y and z. \r\n\r\nNote: The origin (coordinate system/projection) of the position must be specified.\r\n</engelsk>"
    geometry posisjon: Punkt
  "forklaring av hva som er utført og/eller observert i denne undersøkelsen\r\n\r\n<engelsk>\r\na general description of actions performed and/or observed in this investigation\r\n</engelsk>"
    boreBeskrivelse "description"?: CharacterString
  "detaljert beskrivelse av borhullets geometri, dvs. et en-dimensjonalt referansesystem nedover i senterlinjen av borehullet\r\n\r\n<engelsk>\r\ndetailed description of the borehole geometry, i.e. a one-dimensional reference system along the borehole centerline\r\n</engelsk>"
    geometry borehullForløp "drilledCurve,  geometryCurve..."?: Kurve
  "vinkelen mellom en referansevektor i et referanseplan og en annen vektor i det samme planet som peker mot noe av interesse [°]\r\n\r\n<engelsk>\r\nThe vector from an observer (origin) to a point of interest is projected perpendicularly onto a reference plane, the angle between the projected vector and the reference vector on the reference plane is called the azimuth\r\n</engelsk>"
    boretAzimuth?: Real
  "helning hvor 90 grader er vertikalt, 0 grader er horisontalt [°]\r\n\r\n<engelsk>\r\nthe inclination of the borehole\r\n\r\nNote: 90 degrees represent the vertical inclination and 0 degrees the horizontal\r\n</engelsk>"
    boretHelningsgrad "inclination, slope"?: Real
  "total lengde av borehullets forløp, tilsvarer dyp ved vertikal boring [m]\r\n\r\n<engelsk>\r\ntotal length of the investigation in the physical borehole, the same as depth in a vertical borehole\r\n</engelsk>"
    boretLengde "boringLength (Depth),"?: Real
  "dybde til fjell som ikke er målt men basert på tolkning\r\n\r\n<engelsk>\r\ndepth to bedrock based on interpretation\r\n</engelsk>"
    boretLengdeTilBerg?: BorlengdeTilBerg
  "avstanden fra måleutstyret og ned til det punkt på jordoverflaten hvor boring/måling faktisk starter [m]\r\n\r\nMerknad: Borehullundersøkelsens posisjon er vanligvis angitt med x,y,z-koordinat. Disse verdiene representerer vanligvis et punkt på jordoverflaten. Dybden fra denne gitte posisjon vil da være 0. Hvis boringen derimot er utført fra flåte,  skip eller is, er det viktig at dybdeFraGittPosisjon blir angitt. Denne vil da være avstanden fra måleutstyrets senter (0 dybde) og ned til havbunnen, innsjøbunnen eller elvebunnen hvor sonderingen/boringen faktisk starter fra).\r\n\r\n<engelsk>\r\ndistance from the drill or measure equipment down to the vertical level where the borehole/measurement actually begins\r\n\r\nNote: This is important to specify if the drilling/sounding is performed from e.g. a raft, ship or from ice. The depth will then be the depth from the measuring equipments origin (0 depth) and down to where drilling/sounding actually begins (on the sea surface, bottom of a lake or river, etc.)\r\n\r\n</engelsk>"
    dybdeFraGittPosisjon "depthFromRaft"?: Real
  "den lengden hvor sonderingsutstyret befinner seg i vann [m]\r\n\r\nMerknad: Av spesiell interesse hvis boring er utført fra is eller fra flåte/skip.\r\n\r\n<engelsk>\r\nfree water depth at the location of the sounding [m] \r\n\r\nNote: Of special interest if drilling is performed from raft or ice.\r\n</engelsk>"
    dybdeFraVannoverflaten "freeWaterDepth"?: Real
  "lenke til hvor en finner tilleggsinformasjon om borehullsundersøkelsen\r\n\r\nMerknad: URL/URI for aktuelt dokument, bilde, video etc. \r\n\r\n<engelsk>\r\nlink to extra information about the borehole investigation\r\nNote: URL/URI for the particular document, picture, video \r\n</engelsk>"
    lenkeTilTileggsinfo?: CharacterString
  "referanse til opphavsmaterialet, kildematerialet, organisasjons/publiseringskilde\r\n\r\nMerknad: \r\nKan også beskrive navn på person og årsak til oppdatering\r\n\r\n<engelsk>\r\nreference to copyright, source, organization/publication source\r\n\r\nNote: May also include name of person and cause of update\r\n\r\n</engelsk>"
    opphav "serialNumber"?: CharacterString
  "tidspunkt for stopp av undersøkelsen\r\n<engelsk>\r\nend time/date for the investigation\r\n</engelsk>"
    undersøkelseSlutt "investigationEndDate"?: DateTime
  "tidspunkt for start av undersøkelsen\r\n<engelsk>\r\nstart time/date for the investigation\r\n</engelsk>"
    undersøkelseStart "investigationStartDate"?: DateTime
  "beskrivelse av værforhold under utførelsen av borehullundersøkelsen\r\n<engelsk>\r\nWeather conditions - general description.\r\n</engelsk>"
    værforholdVedBoring "weatherConditions"?: CharacterString
}

abstract layer "abstrakt objekt som bærer en rekke egenskaper som er fagområde-uavhengige og kan benyttes for alle objekttyper\r\n\r\nMerknad:\r\nSpesielt i produktspesifikasjonsarbeid vil en velge egenskaper og av grensningslinjer fra denne klassen."
  Supertype_Geotekn_obj_omr {
  "unik identifikasjon av et objekt \r\n\r\nMerknad: Bør bruke UUID.  se http://en.wikipedia.org/wiki/UUID\r\nDe som ikke benytter UUID må selv sørge for at denne er globalt unik."
    identity identifikasjon: Identifikasjon
  "dato for siste endring på objektetdataene \r\n\r\nMerknad: \r\nOppdateringsdato kan være forskjellig fra Datafangsdato ved at data som er registrert kan bufres en kortere eller lengre periode før disse legges inn i datasystemet (databasen).\r\n\r\n-Definition-\r\nDate and time at which this version of the spatial object was inserted or changed in the spatial data set."
    oppdateringsdato?: DateTime
}

abstract layer "abstrakt objekt som bærer en rekke egenskaper som er fagområde-uavhengige og kan benyttes for alle objekttyper\r\n\r\nMerknad:\r\nSpesielt i produktspesifikasjonsarbeid vil en velge egenskaper og av grensningslinjer fra denne klassen."
  Supertype_Geotekn_obj_pkt {
  "dato når objektet siste gang ble registrert/observert/målt i terrenget\r\n\r\nMerknad: I mange tilfeller er denne forskjellig fra Oppdateringsdato, da registrerte endringer kan bufres i en kortere eller lengre periode før disse legges inn i databasen.\r\nVed førstegangsregistrering settes Datafangstdato lik førsteDatafangstdato."
    datafangstdato?: DateTime
  "kartmålestokk registreringene/ datene er hentet fra/ registrert på\r\n\r\nEksempel: 1:50 000 = 50000."
    digitaliseringsmålestokk?: Integer
  "unik identifikasjon av et objekt \r\n\r\nMerknad: Bør bruke UUID.  se http://en.wikipedia.org/wiki/UUID\r\nDe som ikke benytter UUID må selv sørge for at denne er globalt unik."
    identity identifikasjon: Identifikasjon
  "beskrivelse av kvaliteten på stedfestingen"
    kvalitet?: PosisjonskvalitetNADAG
  "dato for siste endring på objektetdataene \r\n\r\nMerknad: \r\nOppdateringsdato kan være forskjellig fra Datafangsdato ved at data som er registrert kan bufres en kortere eller lengre periode før disse legges inn i datasystemet (databasen).\r\n\r\n-Definition-\r\nDate and time at which this version of the spatial object was inserted or changed in the spatial data set."
    oppdateringsdato?: DateTime
}

datatype "dybde til fjell som ikke er målt men basert på tolkning\r\n\r\n<engelsk>\r\ndepth to bedrock based on interpretation\r\n</engelsk>"
  BorlengdeTilBerg {
  "beskriver om dybden til berg er antatt eller påvist med en sikker metode\r\n\r\n<engelsk> \r\ndefines the quality of the depth information either assumed or confirmed by a secure method\r\n</engelsk>"
    borlengdeKvalitet: KvalitetBorlengdeTilBerg
  "dybde til fjell som ikke er målt men basert på tolkning [m]\r\n\r\n<engelsk>\r\ndepth to bedrock based on interpretation\r\n</engelsk>"
    borlengdeTilBerg: Real
}

datatype "data fra måling av setning ved angitt måletidspunkt<engelsk>data from measurements of settlements at a given time</engelsk>"
  DeformasjonMaaleData "SettingMesurementData" {
  "dato for utførelse av målingen<engelsk>date for measurements</engelsk>"
    måleDato "observationDate"?: Date
  "tidspunkt for gjennomføring av målingen<engelsk>time for measurements</engelsk>"
    måleTidspunkt "observationTime"?: DateTime
  "observasjonskoder for markering av hendelser i setningsmålingen<engelsk>observation codes for marking of incidents during the measurements</engelsk>"
    deformasjonObservasjonKode?: DeformasjonObservasjonKode
  "merknad til observasjoner i setningsmålingen<engelsk>remarks to observations made during the measurements</engelsk>"
    observasjonMerknad "remark"?: CharacterString
  "vertikal komponent av målt deformasjon. observert høydenivå (z) for setningsmåling [m] <engelsk>vertical component of measured deformation. observed reference level (z) for the settlements</engelsk>"
    setning "setting"?: Real
  "deformasjonskomponent i x-retning. observert høydenivå (z) for setningen [m]<engelsk>deformation component in x-direction. observed reference level (z) for the settlements</engelsk>"
    deformasjonX "setting"?: Real
  "deformasjonskomponent i y-retning. observert høydenivå (z) for setningen [m]<engelsk>deformation component in y-direction. observed reference level (z) for the settlements</engelsk>"
    deformasjonY "setting"?: Real
  "deformasjonskomponent i z-retning. observert høydenivå (z) for setningen [m]<engelsk>deformation component in z-direction. observed reference level (z) for the settlements</engelsk>"
    deformasjonZ "setting"?: Real
  "gyldighet av data, hvis falsk så er det kun til informasjon <engelsk> validity of data, if false only to be used as information</engelsk>"
    erGyldig "isValid"?: Boolean
  "total lengde av borehullets forløp, tilsvarer dyp ved vertikal boring [m] <engelsk>total length of the investigation in the physical borehole, the same as depth in a vertical borehole</engelsk>"
    boretLengde "length"?: Real
  "observasjonskoder for markering av hendelser. Kodene er (0..*) tallkoder gitt i en tekststreng med mellomrom mellom hver kode hvis mer enn 1. Kodene er beskrevet i kodelisten GeotekniskBoreObservasjonskode.\r\n<engelsk>observation codes for marking of incidents. The codes are (0..*) numeric codes given in a text string with spaces between each code if more than 1. The codes are described in the code list GeotekniskBoreObservasjonskode.</engelsk>"
    observasjonKode?: CharacterString
}

datatype "data fra overvåkning av setningsmåling, grunnvannsstand, poretrykk, rystelser eller andre overvåkningsdata<engelsk>data from supervision of settlements, groundwater table, pore pressure or any other supervision data</engelsk>"
  DeformasjonOvervaakningData {
  "kriterium for alarmtilstand, nedre grense for måleverdi [m] <engelsk>criterion for alarm conditions, lower limit for measured value</engelsk>"
    nedreAlarmNivå "alarmLowerLevel"?: Real
  "kriterium for alarmtilstand, øvre grense for måleverdi [m] <engelsk>criterion for alarm conditions, upper limit for measured value</engelsk>"
    øvreAlarmNivå "alarmUpperlevel"?: Real
  "dato for utførelse av målingen\r\n<engelsk>date for measurements</engelsk>"
    måleDato "observationDate"?: Date
  "tidspunkt for gjennomføring av målingen<engelsk>time for measurements</engelsk>"
    måleTidspunkt "observationTime"?: DateTime
  "merknad til observasjoner i setningsmålingen<engelsk>remarks to observations made during the measurements</engelsk>"
    observasjonMerknad "remark"?: CharacterString
  "grunnvannsmagasin <engelsk>aquifer (ground water reservoir)</engelsk>"
    akvifer "aquifer"?: AkviferType
}

datatype "en enkel innretning, formet som et flatt blad designet for å trykkes ned i bakken. Merknad: ble utviklet for å bestemme modulus for en jordart.\r\n<engelsk>a simple device, shaped in the form of a flat blade designed to be pushed into the ground Note: It was developed to evaluate the soil modulus.</engelsk>"
  DilatometerTestData "DilatometerTestData" {
  "dybde fra 0 nivå, hvor z verdien til undersøkelsens posisjon er satt til 0. Angir hvor dypt det er boret [m] \r\n<engelsk>depth from zero level, the z value of investigation start point is 0. drilling depth\r\n</engelsk>"
    boretDybde "depth"?: Real
  "tekst som beskriver observasjonen <engelsk>description of the observation</engelsk>"
    observasjonMerknad "remark"?: CharacterString
  "kode som angir observasjonen. Kodene er (0..*) tallkoder gitt i en tekststreng med mellomrom mellom hver kode hvis mer enn 1. Kodene er beskrevet i kodelisten GeotekniskBoreObservasjonskode.<engelsk>observation code according to valid codes. The codes are (0..*) numeric codes given in a text string with spaces between each code if more than 1. The codes are described in the code list GeotekniskBoreObservasjonskode. </engelsk>"
    observasjonKode "remarkCode"?: CharacterString
  "gasstrykk når membran ikke lenger har kontakt [kPa] <engelsk>membrane lift-off pressure</engelsk>"
    kontaktTrykkP0?: Real
  "gasstrykk når senter av membran har flyttet seg 1,1 mm [kPa] <engelsk>gass pressure when membrane has moved 1,1 mm</engelsk>"
    ekspansjonTrykkP1?: Real
  "horisontal last [kN] <engelsk>horizontal load</engelsk>"
    horisontalKraft "sidePressure"?: Real
  "trykket i porevannet angitt som kraft pr. flateenhet, med atmosfæretrykket som nullpunkt [kPa]\r\n<engelsk>registered pore pressure (kPa)</engelsk>"
    poretrykk "porePressure"?: Real
}

datatype "data fra måling av dissipasjon (drenasje) i felt, aktuelt ved utførelse av dissipasjonstest i CPTU<engelsk>data fra måling av dissipasjon (drenasje) i felt, aktuelt ved utførelse av dissipasjonstest i CPTU</engelsk>"
  DissipasjonData "DissipationData" {
  "nivå for utførelse av dissipasjonstest [m] <engelsk>depth below the terrain surface or any other given reference level</engelsk>"
    boretDybde "depth"?: Real
  "reduksjon av poretrykk i filterposisjon 1 (spiss) som funksjon av tid i dissipasjonstest [kPa] <engelsk>reduction of pore pressure at filter location 1 (tip) as a function of time in a dissipation test</engelsk>"
    dissipasjonsPoretrykkU1 "dissipationPorePressureU1"?: Real
  "reduksjon av poretrykk i filterposisjon 2 (bak spiss) som funksjon av tid i dissipasjonstest [kPa] <engelsk>reduction of pore pressure at filter location 2 (behind the tip) as a function of time in a dissipation test</engelsk>"
    dissipasjonsPoretrykkU2 "dissipationPorePressureU2"?: Real
  "reduksjon av poretrykk i filterposisjon 3 (bak friksjonshylse) som funksjon av tid i dissipasjonstest [kPa] <engelsk>reduction of pore pressure at filter location 3 (behind the friction sleeve) as a function of time in a dissipation test</engelsk>"
    dissipasjonsPoretrykkU3 "dissipationPorePressureU3"?: Real
  "angitt tidspunkt i dissipasjonstest<engelsk>given time in a dissipation test</engelsk>"
    dissipasjonsTidspunkt "dissipationTime"?: DateTime
  "målt sidefriksjon ved nedpressing av trykksonde (friksjonskraft dividert med areal av friksjonshylse) [kPa] <engelsk>measured sleeve friction during penetration of the probe (friction sleeve force divided by area of the friction sleeve)</engelsk>"
    friksjon "frictionalResistance"?: Real
  "observasjonskoder for markering av hendelser i dissipasjonstesten. Kodene er (0..*) tallkoder gitt i en tekststreng med mellomrom mellom hver kode hvis mer enn 1. Kodene er beskrevet i kodelisten GeotekniskBoreObservasjonskode. \r\n<engelsk>observation codes for marking of incidents during dissipation. The codes are (0..*) numeric codes given in a text string with spaces between each code if more than 1. The codes are described in the code list GeotekniskBoreObservasjonskode.</engelsk>"
    observasjonKode?: CharacterString
  "merknad til observasjoner i dissipasjonstesten <engelsk>remarks to observations made during dissipation</engelsk>"
    observasjonMerknad?: CharacterString
  "poretrykk som utvikles i filterposisjon 1 (spiss) ved nedpressing av trykksonde [kPa] <engelsk>pore pressure generated at filter position 1 (tip) during penetration of the probe</engelsk>"
    poretrykk1 "porePressure1"?: Real
  "poretrykk som utvikles i filterposisjon 2 (bak spiss) ved nedpressing av trykksonde [kPa] <engelsk>pore pressure generated at filter position 2 (behind the tip) during penetration of the probe</engelsk>"
    poretrykk2 "porePressure2"?: Real
  "poretrykk som utvikles i filterposisjon 3 (bak friksjonshylse) ved nedpressing av trykksonde  [kPa] <engelsk>pore pressure generated at filter position 3 (behind the sleeve) during penetration of the probe</engelsk>"
    poretrykk3 "porepressure3"?: Real
  "målt spissmotstand ved nedpressing av trykksonde (spisskraft dividert med tverrsnittsareal av trykksonde) [MPa] <engelsk>measured cone resistance during penetration of the probe (point load divided by cross-sectional area of probe)</engelsk>"
    spissmotstand "pointPressure"?: Real
}

datatype "innsamlede data for utførelse og registrering ved gjennomføring av slagsondering\r\n<engelsk>collected data for performance of and recordings during percussion sounding</engelsk>"
  DynamiskSonderingData "DynamicSoundingData" {
  "boret dybde i forhold til terrengoverflaten eller annet angitt referansenivå [m] <engelsk>drilled depth related to the terrain surface or any other given reference level</engelsk>"
    boretLengde "depth": Real
  "anvendt dreiemoment på borstrengen ved penetrasjon og rotasjon av stangsystemet [kNm] <engelsk>torque applied on the rod system during penetration and rotation of the drill string</engelsk>"
    dreieMoment "torsionMoment"?: Real
  "høyde for slagenhet over topp av stangsystemet i sonderingen [m] <engelsk>level of the percussive unit above the top of the rod system during sounding</engelsk>"
    fallHøyde?: Real
  "markering av rotasjon ved penetrasjon av borstreng\r\n<engelsk>marking of rotation during penetration of the drill string</engelsk>"
    harRotasjon "hasTurning"?: Boolean
  "tidsregistrering under nedpressing av stangsystemet, målt per meter [sek/m] <engelsk> time record during penetration of the rod system, referring to the previous depth /engelsk>"
    nedpressingTid "penetrationTime"?: Integer
  "observasjonskoder for markering av hendelser i sonderingen. Kodene er (0..*) tallkoder gitt i en tekststreng med mellomrom mellom hver kode hvis mer enn 1. Kodene er beskrevet i kodelisten GeotekniskBoreObservasjonskode. \r\n<engelsk>observation codes for marking of incidents during sounding. The codes are (0..*) numeric codes given in a text string with spaces between each code if more than 1. The codes are described in the code list GeotekniskBoreObservasjonskode. </engelsk>"
    observasjonKode "remarkCode"?: CharacterString
  "merknad til observasjoner i sonderingen\r\n<engelsk>remarks to observations made during sounding</engelsk>"
    observasjonMerknad "remark, obervationRemark"?: CharacterString
  "markering av prøvenummer ved opptak av fysisk prøvemateriale under sonderingen<engelsk>marking of sample number in collection of sampled material during sounding</engelsk>"
    prøveuttakNummer?: CharacterString
  "penetrasjonsmotstand mot ramming av borstrengen uttrykt i synk per antall påførte slag [slag/0,2m] <engelsk>penetration resistance on the hammered drill string expressed in sink per number of applied strokes</engelsk>"
    ramMotstand?: Real
  "antall omdreininger av stangsystemet per tidsenhet ved penetrasjon av borstrengen [omdr/min] <engelsk>number of turns of the rod system per time unit during penetration of the drill string</engelsk>"
    rotasjonHastighet "rateOfTurning"?: Real
  "slagfrekvens ved anvendelse av slag på borstrengen [slag/min] <engelsk>stroke frequency during application of strokes on the drill string in rock control mode, defined by the number of strokes per time unit</engelsk>"
    slagFrekvens "rateOfPiling ..."?: Real
}

datatype "Identifikasjon av et objekt, ivaretatt av den ansvarlige leverandør inn til NADAG."
  EksternIdentifikasjon "Identification" {
  "lokal identifikator, tildelt av ekstern leverendør. \r\nDet er data leverendørens ansvar å sørge for at denne eksterne identifikatoren er unik innenfor navnerommet."
    eksternId "externalId"?: CharacterString
  "navnerom som identifiserer datakilden/leverandør til objektet"
    eksternNavnerom "externalNamespace"?: CharacterString
  "identifikasjon av en spesiell versjon av et geografisk objekt  Dersom spesifikasjonen av et geografisk objekt med en identifikasjon inkludererer livsløpssyklusinformasjon, benyttes denne versjonId for å skille mellom ulike versjoner av samme objekt. versjonId er en unik  identifikasjon av versjonen."
    eksternVersjonId "externalVersionid"?: CharacterString
  "Når objektet ble levert til database (Nadag)"
    eksternLeveringDato "externalDeliveryDate"?: DateTime
}

datatype "resultater fra gassmålinger<engelsk>results from gas measurements</engelsk>"
  GassData "GasData" {
  "innhold av metangass i poreluften<engelsk>content of methane gass in pore air</engelsk>"
    CH4?: Real
  "innhold av kvikksølv i poreluften<engelsk>content of mercury in pore air</engelsk>"
    HG?: Real
}

layer "delprøve av en  prøveserie<engelsk> Soil test part </engelsk>"
  GeotekniskProeveseriedel "SoilTestPart" {
  "metode benyttet for å ta prøven<engelsk>method identifier</engelsk>"
    prøveMetode "method"?: CharacterString
  "navn på prøveseriedelen<engelsk>name</engelsk>"
    prøveseriedelNavn "name"?: CharacterString
  "lengde målt fra toppen av kurven/linja som beskriver borehullforløpet [m] <engelsk>the start length, the depth at top of the specimen[m]</engelsk>"
    fraLengde "startLength"?: Real
  "lengde målt fra toppen av kurven/linja som beskriver borehullforløpet [m] <engelsk>the length of the stop, the lower depth limitation of the sample [m]</engelsk>"
    tilLengde "stopLength"?: Real
  "Primærnøkkel for relasjon"
    identity prøveseriedelId: CharacterString
  parent tilhørerPrøveserie?: GeotekniskProeveserie
  harData*: GeotekniskProeveseriedelData
}

datatype "Data som tilhører en geoteknisk prøveseriedel <engelsk>Data for a soil test part </engelsk>"
  GeotekniskProeveseriedelData "SoilTestPartProtocolData" {
  "i hvilken del av prøvedelen som det er gjort undersøkelser"
    lagPosisjon "layerComposition"?: LagPosisjon
  "metode benyttet for å ta prøven<engelsk>method identifier</engelsk>"
    prøveMetode "method"?: CharacterString
  "angis i [%] <engelsk> the axial deformation (bruddef) %</engelsk>"
    aksielDeformasjon "axialDeformation"?: Real
  "bestemmelse av udrenert skjærfasthet ved enaksial trykkprøving i laboratoriet [kPa] <engelsk>the axial shear strength, the undrained shear strength by unconfined compression testing (sue) [kPa].</engelsk>"
    skjærfasthetUdrenert "axialShearStrength"?: Real
  "tekst som beskriver lagsammensetningen <engelsk>the detailed layer composition, a text containing a detailed layer composition</engelsk>"
    detaljertLagSammensetning "detailedLayerComposition"?: CharacterString
  "skjærfasthet for en kohesjonsjordart med fullstendig omrørt struktur [kPa] <engelsk>the shear strength for a remoulded test material (suo) [kPa]</engelsk>"
    skjærfasthetOmrørt "disturbedShearStrength"?: Real
  "vekt pr. volumenhet [kg/m3] <engelsk>weight by unit of space (kg/m3)</engelsk>"
    densitetPrøvetaking "gravity"?: Real
  "om prøvserien er omrørt<engelsk>indicating whether a soil test is disturbed</engelsk>"
    erOmrørt "isDistubed"?: Boolean
  "om prøven har blitt analysert på laboratorium\r\n<engelsk> indicating whether the soil test has been analyzed at laboratory</engelsk>"
    labAnalyse "isLab"?: Boolean
  "bestemmelse av flytegrense ved hjelp av støt- eller konusmetode i laboratoriet [%] Merknad: Flytegrensen angir det vanninnhold der en omrørt leire går over fra å være flytende til å bli plastisk (formbar) <engelsk>determination of liquid limit flytegrense by percussionor fall cone method in the laboratory Note:The liquid limit corresponds to a water content where the remoulded material goes from a liquid to a plastic state</engelsk>"
    flyteGrense "liquidLimit"?: Real
  "angis i [%] <engelsk>the loss on ignition, the loss of mass (% left of initial mass) due to heating</engelsk>"
    glødeTap "lossOfIgnition"?: Real
  "bestemmelse av plastisitetsgrense ved hjelp av utrullingsmetode [%]  Merknad: Også kalt utrullingsgrense som angir det vanninnhold der en omrørt leire går over fra plastisk (formbar) til smuldrende konsistens <engelsk>determination of the plasticity limit by a hand rolling method Note: Expresses the water content where a remoulded clay leaves the plastic state and starts to crumble</engelsk>"
    plastitetsGrense "plasticityLimit"?: Real
  "forholdet mellom uforstyrret og omrørt udrenert skjærfasthet for kohesjonsjord<engelsk>ratio between undisturbed and remoulded undrained shear strength for cohesive soils</engelsk>"
    sensitivitet "sensitivity"?: Real
  "skjærfasthet for en kohesjonsjordart med uforstyrret, intakt struktur [kPa] <engelsk>shear strength for cohesive soils with an intact, undisturbed structure</engelsk>"
    skjærfasthetUforstyrret "undisturbedShearStrength"?: Real
  "boret lengde i forhold til terrengoverflaten eller annet angitt referansenivå [m] <engelsk>drilled length related to the terrain surface or any other given reference level</engelsk>"
    boretLengde "length"?: Real
  "undersøkelse for bestemmelse av prøvematerialets vanninnhold ved tørking. Angir forholdet mellom masse vann og masse fast stoff [%] <engelsk>determination of the water content of the sample by oven drying. Corresponds to the ratio between mass of water and the mass of solid particles</engelsk>"
    vanninnhold "waterContent"?: Real
  "observasjonskoder for markering av hendelser i sonderingen. Kodene er (0..*) tallkoder gitt i en tekststreng med mellomrom mellom hver kode hvis mer enn 1. Kodene er beskrevet i kodelisten GeotekniskBoreObservasjonskode.\r\n<engelsk>observation codes for marking of incidents during sounding. The codes are (0..*) numeric codes given in a text string with spaces between each code if more than 1. The codes are described in the code list GeotekniskBoreObservasjonskode.</engelsk>"
    observasjonKode "remarkCode"?: CharacterString
  "merknad til observasjoner i sonderingen<engelsk>remarks to observations made during sounding</engelsk>"
    observasjonMerknad "remark"?: CharacterString
}

datatype "data fra måling av grunnvannstand, med observasjonskoder, kommentarer og tidsstempel for angitt måletidspunkt<engelsk>data from measurement of ground water level, with observation codes, comments and time for measurements</engelsk>"
  GrunnvannData "GroundWaterMeasurementData" {
  "dato for utførelse av grunnvannsmålingen<engelsk>date for measurements</engelsk>"
    måleDato "measureDate"?: Date
  "angivelse av vannstand i grunnen og/eller i målerør (z-nivå) [m] <engelsk>water level in the ground and / or inside a measurement tube (z-level)</engelsk>"
    dybdeGrunnvannstand "groundWaterDept, groundWaterLevel"?: Real
  "tidspunkt for gjennomføring av grunnvannsmålingen<engelsk>time for measurements</engelsk>"
    måleTidspunkt "measureTime"?: DateTime
  "observasjonskoder for markering av hendelser i grunnvannsmålingen. Kodene er (0..*) tallkoder gitt i en tekststreng med mellomrom mellom hver kode hvis mer enn 1. Kodene er beskrevet i kodelisten GeotekniskBoreObservasjonskode.<engelsk>observation codes for marking of incidents during ground water measurements. The codes are (0..*) numeric codes given in a text string with spaces between each code if more than 1. The codes are described in the code list GeotekniskBoreObservasjonskode.</engelsk>"
    observasjonKode "remarkCode"?: CharacterString
  "merknad til observasjoner i grunnvannsmålingen<engelsk>remarks to observations made during ground water measurements</engelsk>"
    observasjonMerknad "remark"?: CharacterString
  "surhetsgrad <engelsk><measure of acidity>"
    pH?: Real
  "hydraulisk ledningsevne [uS/cm] <engelsk>hydraulic conductivity</engelsk>"
    ledningsevne?: Real
  "innhold av oksygen [ml] <engelsk>oxygen content</engelsk>"
    oksygenInnhold?: Real
  "temperatur [°C] <engelsk>temperature [°C]</engelsk>"
    temperatur?: Real
  "red-oks-potensiale [mV] <engelsk>redox potential</engelsk>"
    redoks?: Real
  "angir gjennomsnittlig partikkelinnhold [NTU] <engelsk>average particle content</engelsk>"
    turbiditet?: Real
  "total lengde av borehullets forløp, tilsvarer dyp ved vertikal boring [m] <engelsk>total length of the investigation in the physical borehole, the same as depth in a vertical borehole</engelsk>"
    boretLengde "length"?: Real
  "observasjonskoder for grunnvann"
    grunnvannObservasjonKode "GroundwaterObservationCode"?: GeotekniskGrunnvannObservasjonKode
  "gyldighet av data, hvis falsk så er det kun til informasjon <engelsk> validity of data, if false only to be used as information</engelsk>"
    erGyldig "isValid"?: Boolean
}

datatype "data fra måling av vannstrømning, vannhastighetsbestemmelse og hydraulisk splitting i felt.             <engelsk>data from measurements of water flow, water velocity, pumping tests and hydraulic splitting in the field.                                                         </engelsk>"
  HydrauliskeData "HydraulicData" {
  "dato for utførelse av målingen<engelsk>date for measurements</engelsk>"
    måleDato "measureDate"?: Date
  "tidspunkt for utførelse av målingen<engelsk>time for measurements</engelsk>"
    måleTidspunkt "measureTime"?: DateTime
  "merknad til observasjoner i hydraulisk test<engelsk>remarks to observations made during hydraulic testing</engelsk>"
    observasjonMerknad "remark"?: CharacterString
  "jordparameter som beskriver hydraulisk ledningsevne [m/s] <engelsk>soil parameter which describes hydraulic conductivity</engelsk>"
    hydrauliskKonduktivitet?: HydrauliskKonduktivitet
  "angivelse av vannstand i grunnen og/eller i målerør [m] <engelsk>water level in the ground and / or inside a measurement tube</engelsk>"
    dybdeGrunnvannstand "groundWaterDept, groundWaterLevel"?: Real
}

datatype "Data som tilhører en Kjerneboring"
  KjerneBoringData "KjerneBoringData" {
  "boret lengde i forhold til terrengoverflaten eller annet angitt\r\nreferansenivå<engelsk>drilled length related to the terrain surface or any other given reference level</engelsk>"
    boretLengde "length"?: Real
  forvitringsgrad "rockWeatheringDegree"?: CharacterString
  geologiskMaterialTekst "materialText"?: CharacterString
  geologiskMaterialType "materialType"?: CharacterString
  "Prosent av siste kjerne som er opptatt<engelsk> the total core recovery, percent received core of the previous section [%]</engelsk>"
    kjerneOpptak_Prosent "totalCoreRecovery"?: Integer
  materialStruktur "materialStructure"?: CharacterString
  "observasjonskoder for markering av hendelser i sonderingen. Kodene er (0..*) tallkoder gitt i en tekststreng med mellomrom mellom hver kode hvis mer enn 1. Kodene er beskrevet i kodelisten GeotekniskBoreObservasjonskode.\r\n<engelsk>observation codes for marking of incidents during sounding. The codes are (0..*) numeric codes given in a text string with spaces between each code if more than 1. The codes are described in the code list GeotekniskBoreObservasjonskode.</engelsk>"
    observasjonKode "remarkCode"?: CharacterString
  "merknad til observasjoner i sonderingen<engelsk>remarks to observations made during sounding</engelsk>"
    observasjonMerknad "remark"?: CharacterString
  opptrekk "uptake"?: CharacterString
  "Tall for sprekkefylling"
    QVerdi_Ja "QValue_Ja"?: Real
  "Tall for sprekkesett"
    QVerdi_Jn "QValue_Jn"?: Real
  "Sprekkeruhetstall"
    QVerdi_Jr "QValue_Jr"?: Real
  "Sprekkevannstall"
    QVerdi_Jw "QValue_Jw"?: Real
  "Q=(RQD/Jn)*(Jr/Ja)*(Jw/SRF)"
    QVerdi_Q "QValue_Q"?: Real
  "om Q-verdiet er beregnet basert på de øvrige leverte verdier eller kommer fra annen kilde <engelsk>indicating whether the Q-value is computed from the associated values or is external</engelsk>"
    QVerdi_QErBeregnet "QValue_QIsComputed"?: Boolean
  "Oppsprekkingstall (Rock Quality Designation)"
