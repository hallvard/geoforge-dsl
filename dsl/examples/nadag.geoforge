    rørBunn "bottomOfTube"?: Real
  "identifikasjon av poretrykksmåler/måleapparat<engelsk>identification of the pore pressure device/measuring unit</engelsk>"
    målerspissNummer "measurePointNumber"?: CharacterString
  "kategori poretrykksmåler (åpen, hydraulisk, elektrisk<engelsk>cathegory of the pore pressure device (open, hydraulic, electrical</engelsk>"
    målerKategori "measureType"?: PoretrykkMaaleKategori
  "type poretrykksmåler (fabrikat, produsent)<engelsk>type of pore pressure device</engelsk>"
    målerType "measureType"?: CharacterString
  poretrykkObservasjon*: PoretrykkData
}

