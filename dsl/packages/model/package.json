{
    "name": "geoforge-model",
    "description": "The model specific package",
    "version": "0.0.1",
    "type": "module",
    "engines": {
        "node": ">=20.10.0",
        "npm": ">=10.2.3"
    },
    "files": [
        "bin",
        "out",
        "src"
    ],
    "main": "./out/model.js",
    "module": "./out/model.js",
    "bin": {
    },
    "exports": {
        "./model": {
            "types": "./out/model.d.ts",
            "default": "./out/model.js"
        }
    },
    "typesVersions": {
        "*": {
            "model": [
                "out/model"
            ]
        }
    },
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out",
        "build": "echo 'No build step'",
        "build:clean": "npm run clean && npm run build"
    },
    "dependencies": {
    },
    "volta": {
        "node": "20.19.2",
        "npm": "10.8.2"
    }
}
